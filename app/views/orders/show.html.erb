<div class="min-h-screen bg-base-100 p-4 md:p-8">
  <div class="container mx-auto max-w-5xl">

    <%# Navigation %>
    <div class="mb-6">
      <%= link_to root_path, class: "btn btn-ghost btn-sm gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Dashboard
      <% end %>
    </div>

    <%# Header Section %>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold flex items-center gap-3">
          Order Details
          <span class="text-primary opacity-50 text-xl font-mono">
            #<%= @order.order_number || @order.shopify_order_id %>
          </span>
        </h1>
        <p class="text-base-content/60">Complete order information from Shopify webhook</p>
      </div>

      <div class="badge badge-lg gap-2 font-bold p-4
        <%= case @order.status
            when 'pending' then 'badge-warning'
            when 'completed' then 'badge-success'
            else 'badge-ghost'
            end %>">
        <%= @order.status.capitalize %>
      </div>
    </div>

    <%# Key Stats Row %>
    <div class="stats shadow bg-base-200 w-full mb-8">
      <div class="stat">
        <div class="stat-title text-xs uppercase tracking-widest">Total Price</div>
        <div class="stat-value text-primary">$<%= @order.total_price %></div>
        <div class="stat-desc text-base-content/50">Via Shopify</div>
      </div>

      <div class="stat border-l border-base-300">
        <div class="stat-title text-xs uppercase tracking-widest">Shopify ID</div>
        <div class="stat-value text-lg font-mono truncate"><%= @order.shopify_order_id %></div>
        <div class="stat-desc text-base-content/50">External Reference</div>
      </div>

      <div class="stat border-l border-base-300">
        <div class="stat-title text-xs uppercase tracking-widest">Created On</div>
        <div class="stat-value text-lg"><%= @order.created_at.strftime("%b %d, %Y") %></div>
        <div class="stat-desc text-base-content/50"><%= @order.created_at.strftime("%I:%M %p") %></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <%# Customer Info Card %>
      <div class="card bg-base-200 shadow-xl">
        <div class="card-body">
          <h2 class="card-title text-sm uppercase tracking-widest opacity-60">Client Information</h2>
          <div class="flex items-center gap-4 mt-2">
            <div class="avatar placeholder">
              <div class="bg-neutral text-neutral-content rounded-full w-12">
                <span class="text-xl"><%= (@order.client&.shopify_domain || 'U').first.upcase %></span>
              </div>
            </div>
            <div>
              <p class="font-bold leading-tight"><%= @order.client&.shopify_domain || 'Unknown Client' %></p>
              <p class="text-xs opacity-50">Shopify Domain</p>
            </div>
          </div>
        </div>
      </div>

      <%# Line Items Table Card %>
      <div class="lg:col-span-2 card bg-base-200 shadow-xl">
        <div class="card-body p-0">
          <div class="px-8 pt-6 pb-2">
            <h2 class="card-title">Line Items</h2>
          </div>

          <div class="overflow-x-auto">
            <table class="table table-zebra w-full">
              <thead>
              <tr>
                <th>Product</th>
                <th>SKU</th>
                <th>Qty</th>
                <th>Price</th>
                <th class="text-right">Total</th>
              </tr>
              </thead>
              <tbody>
              <% if @order.payload && @order.payload['line_items'] %>
                <% @order.payload['line_items'].each do |item| %>
                  <tr>
                    <td class="font-bold"><%= item['title'] %></td>
                    <td><span class="badge badge-ghost badge-sm"><%= item['sku'] || 'N/A' %></span></td>
                    <td><%= item['quantity'] %></td>
                    <td>$<%= item['price'] %></td>
                    <td class="text-right font-bold text-primary">$<%= item['line_price'] %></td>
                  </tr>
                <% end %>
              <% else %>
                <tr><td colspan="5" class="text-center italic opacity-50">No items found</td></tr>
              <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <%# Raw Payload Accordion %>
    <% if @order.payload %>
      <div class="collapse collapse-arrow bg-base-200 mt-8 shadow-xl">
        <input type="checkbox" />
        <div class="collapse-title text-lg font-medium">
          View Raw Webhook Payload
        </div>
        <div class="collapse-content">
          <div class="mockup-code bg-neutral text-neutral-content mt-2">
            <pre class="px-4"><code><%= JSON.pretty_generate(@order.payload) %></code></pre>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>